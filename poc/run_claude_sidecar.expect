#!/usr/bin/expect -f

set timeout -1

set model [expr {[info exists env(INTERVIEW_MODEL)] ? $env(INTERVIEW_MODEL) : "opus"}]
set effort [expr {[info exists env(INTERVIEW_EFFORT)] ? $env(INTERVIEW_EFFORT) : "low"}]
set project_root [expr {[info exists env(INTERVIEW_PROJECT_ROOT)] ? $env(INTERVIEW_PROJECT_ROOT) : "/Users/oribecher/Projects/interview-helper"}]

set system_prompt "You are the stateful brain for a live interview scratchpad on a second monitor. For every channel event from interview_sidecar, update the same scratchpad by calling the reply tool exactly once. Never answer with prose. Keep it glanceable: question 1 line, short_answer 1-2 lines, formula_or_structure compact and prominent, say_bullets max 3, caveat max 1 line. Prefer formulas, SQL skeletons, experiment steps, and direct concise wording. Preserve continuity across turns and refine as more transcript arrives. If a question is incomplete, return draft with low confidence. Echo the exact Request ID from the latest channel message in reply.request_id."

cd $project_root
spawn claude --model $model --effort $effort --permission-mode bypassPermissions --append-system-prompt $system_prompt --dangerously-load-development-channels server:interview_sidecar

expect {
  -re "Enter to confirm.*cancel" {
    send "\r"
    exp_continue
  }
  -re "Do you trust the files in this folder.*" {
    send "\r"
    exp_continue
  }
  timeout {
    exp_continue
  }
  eof
}

